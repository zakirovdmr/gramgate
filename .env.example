# Telegram MTProto credentials (required)
# Get api_id and api_hash from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION_DIR=./sessions

# REST API settings (optional)
LANDO_API_PORT=18791
LANDO_API_HOST=127.0.0.1
# Set a token to require Authorization: Bearer <token> on all API requests
LANDO_API_TOKEN=

# MCP server (Model Context Protocol) — for AI agent integration
LANDO_MCP_PORT=18792   # 0 = disabled

# Rate limits (0 = disabled, protects your account from Telegram flood bans)
LANDO_RATE_SEND_PER_CHAT=20   # max messages per chat per 60s
LANDO_RATE_SEND_GLOBAL=30     # max messages total per 60s
LANDO_RATE_JOIN=5              # max join/leave/create per hour
LANDO_RATE_API_GLOBAL=25       # max API requests per second

# OpenClaw bridge (optional — leave empty to disable)
# When set, incoming private/mentioned messages are forwarded to OpenClaw for AI responses
OPENCLAW_URL=http://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_MODEL=openclaw
